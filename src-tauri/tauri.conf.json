{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PasteMind",
  "version": "0.1.0",
  "identifier": "com.pastemind.app",
  "build": {
    "beforeDevCommand": "pnpm frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm frontend:build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PasteMind",
        "label": "main",
        "width": 440,
        "height": 640,
        "minWidth": 360,
        "minHeight": 520,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
